# Voice AI Bot Configuration
# Copy this file to .env and fill in your values

# Required Settings
OPENAI_API_KEY=your-openai-api-key-here
COMPANY_NAME=Your Company Name
SALES_BOT_NAME=Zara

# Optional Settings (defaults provided)
SERVER_HOST=0.0.0.0
SERVER_PORT=5002
SAMPLE_RATE=8000
AUDIO_CHUNK_SIZE=200
OPENAI_MODEL=gpt-4o-realtime-preview-2024-12-17
OPENAI_VOICE=coral
LOG_LEVEL=INFO

# ===== SIP TRUNKING: INBOUND ONLY =====
USE_SIP_TRUNK=true
# Receive calls directly from Exotel via SIP (no credentials needed)
# Configuration:
INBOUND_SIP_ENABLED=true
SIP_SERVER_HOST=0.0.0.0
SIP_SERVER_PORT=5060
SIP_PUBLIC_IP=your-public-ip-or-domain.com
MAX_CONCURRENT_CALLS=10

# ===== OUTBOUND CALLS: REST API ONLY =====
# Use Exotel REST API to initiate calls (no SIP credentials)
# Get these from Exotel dashboard
EXOTEL_API_TOKEN=your-exotel-api-token
EXOTEL_ACCOUNT_SID=your-account-sid
EXOTEL_FROM_NUMBER=+91xxxxxxxxxx

# ===== ACTIVE ENGINE SELECTOR =====
# Set to 'modular' for Deepgram + Gemini + Sarvam, or 'realtime' for OpenAI Realtime
VOICE_BOT_MODE=realtime

# ===== MODULAR PIPELINE KEYS =====
DEEPGRAM_API_KEY=your-deepgram-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
SARVAM_API_KEY=your-sarvam-api-key-here

# ===== MODULAR SPECIFICS (MODELS & VOICES) =====
DEEPGRAM_MODEL=nova-2-phonecall
GEMINI_MODEL=gemini-2.5-flash
SARVAM_MODEL=bulbul:v3
SARVAM_SPEAKER=shubh
SARVAM_LANGUAGE_CODE=hi-IN

# ===== AWS S3 RAG STORAGE =====
AWS_S3_BUCKET_NAME=your-s3-bucket-name-here
