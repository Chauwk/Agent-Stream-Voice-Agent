# Voice AI Bot Configuration
# Copy this file to .env and fill in your values

# Required Settings
OPENAI_API_KEY=your-openai-api-key-here
COMPANY_NAME=Your Company Name
SALES_BOT_NAME=Sarah

# Optional Settings (defaults provided)
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SAMPLE_RATE=8000
AUDIO_CHUNK_SIZE=200
OPENAI_MODEL=gpt-4o-realtime-preview-2024-12-17
OPENAI_VOICE=coral
LOG_LEVEL=INFO

# ===== INTEGRATION MODE: Choose one =====
# Option 1: Exotel Voicebot Applet (traditional, higher cost)
# - No additional config needed, bot listens on SERVER_HOST:SERVER_PORT

# Option 2: Direct SIP Trunking (cost-effective, recommended)
# Set USE_SIP_TRUNK=true and configure below:
USE_SIP_TRUNK=false

# SIP Trunk Configuration (only needed if USE_SIP_TRUNK=true)
SIP_SERVER_HOST=0.0.0.0
SIP_SERVER_PORT=5060
SIP_REALM=exotel.com
SIP_USERNAME=your-exotel-sip-username
SIP_PASSWORD=your-exotel-sip-password
EXOTEL_OUTBOUND_PROXY=proxy.exotel.in:5060
SIP_PUBLIC_IP=your-public-ip-or-domain.com

